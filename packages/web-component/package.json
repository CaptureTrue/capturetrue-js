{
  "name": "@capturetrue/web-component",
  "version": "0.0.1",
  "description": "A web component for capturing live photo, built with TypeScript and Web Components.",
  "private": false,
  "main": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup index.ts --format esm,cjs --dts",
    "dev": "npm run build && yalc publish --push",
    "dev:watch": "nodemon --watch 'src/**/*' --exec 'npm run dev'"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "tsup": "^8.5.1"
  }
}
